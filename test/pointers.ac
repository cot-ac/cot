// RUN: %cot test %s

test "address-of and deref" {
  var x: i32 = 10
  let p: *i32 = &x
  let val: i32 = *p
  assert(val == 10)
}

test "deref sees mutation" {
  var x: i32 = 5
  let p: *i32 = &x
  x = 20
  let val: i32 = *p
  assert(val == 20)
}

test "pointer arithmetic result" {
  var a: i32 = 7
  let p: *i32 = &a
  let v: i32 = *p * 6
  assert(v == 42)
}
